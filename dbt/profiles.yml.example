contoso_fabric_dbt:
  target: dev
  outputs:
    dev:
      type: fabric
      driver: "ODBC Driver 18 for SQL Server"
      server: "<your-workspace-id>.datawarehouse.fabric.microsoft.com"
      port: 1433
      database: contoso_warehouse
      schema: dbo
      authentication: CLI
      # authentication options: CLI, ActiveDirectoryInteractive, ActiveDirectoryServicePrincipal
      #
      # CLI auth requires Azure CLI to be logged in:
      #   az login --use-device-code   (recommended for terminal/headless environments)
      #   az login                     (opens browser)
      #
      # For service principal auth, add:
      # tenant_id: "<your-tenant-id>"
      # client_id: "<your-client-id>"
      # client_secret: "<your-client-secret>"
